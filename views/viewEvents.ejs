<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Events - EventFlow</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <%- include('partials/header') %>

    <div class="container py-4">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h1 class="h4 mb-0"><i class="bi bi-list-ul"></i> All Events</h1>
                <a href="/events" class="btn btn-light btn-sm fw-semibold">
                    <i class="bi bi-arrow-left"></i> Back to Dashboard
                </a>
            </div>
            <div class="card-body">
                 <div class="search-filter-section mb-4 p-3 bg-light rounded">
                    <form action="/events/view" method="GET" class="d-flex flex-column flex-md-row gap-2">
                        <div class="flex-grow-1">
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-search"></i></span>
                                <input type="text" name="search" class="form-control" 
                                       placeholder="Search event name or description..." 
                                       value="<%= locals.searchQuery ? searchQuery : '' %>">
                            </div>
                        </div>
                        
                        <div style="min-width: 200px;">
                            <select name="category" class="form-select">
                                <option value="">All Categories</option>
                                <option value="Sports" <%= locals.selectedCategory === 'Sports' ? 'selected' : '' %>>Sports</option>
                                <option value="Academic" <%= locals.selectedCategory === 'Academic' ? 'selected' : '' %>>Academic</option>
                                <option value="Arts" <%= locals.selectedCategory === 'Arts' ? 'selected' : '' %>>Arts</option>
                                <option value="Technology" <%= locals.selectedCategory === 'Technology' ? 'selected' : '' %>>Technology</option>
                                <option value="Seminar" <%= locals.selectedCategory === 'Seminar' ? 'selected' : '' %>>Seminar</option>
                                <option value="Entertainment" <%= locals.selectedCategory === 'Entertainment' ? 'selected' : '' %>>Entertainment</option>
                            </select>
                        </div>
                        
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Search</button>
                            <a href="/events/view" class="btn btn-outline-secondary">Clear</a>
                        </div>
                    </form>
                </div>

                <% if (events.length === 0) { %>
                    <div class="alert alert-info mb-0">No events found.</div>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Event Name</th>
                                    <th>Date</th>
                                    <th>Time</th>
                                    <th>Location</th>
                                    <th>Category</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% events.forEach(function(event) { %>
                                    <tr>
                                        <td><%= event.event_name %></td>
                                        <td><%= event.event_date %></td>
                                        <td><%= event.event_time %></td>
                                        <td><%= event.location %></td>
                                        <td><span class="badge bg-primary"><%= event.category %></span></td>
                                        <td>
                                            <div class="d-flex gap-1">
                                                <a href="/events/view/<%= event.event_id %>" class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-eye"></i> View
                                                </a>
                                                <% if (user && user.role === 'admin') { %>
                                                    <a href="/events/edit/<%= event.event_id %>" class="btn btn-sm btn-outline-primary">
                                                        <i class="bi bi-pencil-square"></i> Edit
                                                    </a>
                                                    <a href="/events/delete/<%= event.event_id %>" class="btn btn-sm btn-outline-danger">
                                                        <i class="bi bi-trash"></i> Delete
                                                    </a>
                                                <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>
</body>
</html>