<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= event.event_name %> - EventFlow</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <%- include('partials/header') %>

    <!-- ========== Your page content starts here ========== -->
    <div class="container mt-4">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h1 class="h4 mb-0"><i class="bi bi-calendar-event"></i> <%= event.event_name %></h1>
                <span class="badge bg-light text-dark"><%= event.category %></span>
            </div>
            <div class="card-body">
                <p><i class="bi bi-card-text"></i> <strong>Description:</strong> <%= event.description %></p>
                <p><i class="bi bi-calendar-event"></i> <strong>Date:</strong> <%= event.event_date %></p>
                <p><i class="bi bi-clock"></i> <strong>Time:</strong> <%= event.event_time %></p>
                <p><i class="bi bi-geo-alt"></i> <strong>Location:</strong> <%= event.location %></p>
            </div>
            
            <div class="card-footer d-flex justify-content-between align-items-center">
                <a href="/events/view" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back to All Events
                </a>
                
                <div class="d-flex gap-2 align-items-center">
                    <% if (user && user.role === 'admin') { %>
                        <a href="/events/edit/<%= event.event_id %>" class="btn btn-primary">
                            <i class="bi bi-pencil-square"></i> Edit
                        </a>
                        <a href="/events/delete/<%= event.event_id %>" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    <% } else if (user && user.role === 'user') { %>
                        
                        <% if (typeof isRegistered !== 'undefined' && isRegistered) { %>
                            <span class="text-success fw-bold me-2">
                                <i class="bi bi-check-circle-fill"></i> Registered
                            </span>
                            <form action="/events/<%= event.event_id %>/cancel" method="POST" class="m-0">
                                <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Are you sure you want to cancel your registration?');">
                                    <i class="bi bi-x-circle"></i> Cancel Registration
                                </button>
                            </form>
                        <% } else { %>
                            <form action="/events/<%= event.event_id %>/register" method="POST" class="m-0">
                                <button type="submit" class="btn btn-success">
                                    <i class="bi bi-person-plus"></i> Register Now
                                </button>
                            </form>
                        <% } %> 
                    <% } %>
                </div> 
            </div>
        </div>
    </div>
    <!-- ========== Your page content ends here ========== -->

    <%- include('partials/footer') %>
</body>
</html>