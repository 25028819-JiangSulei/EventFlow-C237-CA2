<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Preferences - EventFlow</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</head>
<body>

  <%- include('partials/header') %>

  <div class="container mt-5 mb-5">
    <div class="row justify-content-center">
      <div class="col-md-8">
        <div class="card shadow">
          <div class="card-body p-4">
            <h3 class="mb-3"><i class="bi bi-sliders"></i> Tell us what you like</h3>
            <p class="text-muted">Select the types of events you are interested in. We will recommend matching events for you.</p>

            <% if (error && error.length > 0) { %>
              <div class="alert alert-danger"><%= error %></div>
            <% } %>

            <form action="/preferences" method="POST">
              <div class="mb-4">
                <label class="form-label fw-bold">I'm interested in:</label>
                
                <% if (categories.length === 0) { %>
                  <div class="alert alert-warning">No event categories available yet. You can skip for now.</div>
                <% } else { %>
                  <div class="row">
                    <% categories.forEach(cat => { %>
                      <div class="col-md-6 mb-2">
                        <div class="form-check">
                          <input class="form-check-input" type="checkbox" name="categories" 
                                 value="<%= cat.category %>" id="cat_<%= cat.category %>"
                                 <%= userCategories.includes(cat.category) ? 'checked' : '' %>>
                          <label class="form-check-label" for="cat_<%= cat.category %>">
                            <%= cat.category %>
                          </label>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                <% } %>
              </div>

              <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                  <i class="bi bi-save"></i> Save Preferences
                </button>
                <a href="/events" class="btn btn-outline-secondary">
                  Skip for now
                </a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

</body>
</html>