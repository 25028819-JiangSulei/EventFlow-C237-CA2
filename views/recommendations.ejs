<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Recommended Events - EventFlow</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</head>
<body>

  <%- include('partials/header') %>

  <div class="container mt-5 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2><i class="bi bi-stars"></i> Recommended for You</h2>
        <p class="text-muted mb-0">
          Based on your interests:
          <% preferences.forEach(p => { %>
            <span class="badge bg-primary me-1"><%= p %></span>
          <% }) %>
        </p>
      </div>
      <a href="/preferences" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-pencil"></i> Edit Preferences
      </a>
    </div>

    <% if (events.length === 0) { %>
      <div class="alert alert-info">
        No matching events found. Try selecting more categories.
      </div>
    <% } else { %>
      <div class="row">
        <% events.forEach(event => { %>
          <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm">
              <div class="card-body">
                <span class="badge bg-secondary mb-2"><%= event.category %></span>
                <h5 class="card-title"><%= event.event_name %></h5>
                <p class="card-text text-muted small">
                  <%= event.description ? event.description.substring(0, 100) + '...' : 'No description' %>
                </p>
                <p class="mb-1"><i class="bi bi-calendar"></i> <%= event.event_date %></p>
                <p class="mb-1"><i class="bi bi-clock"></i> <%= event.event_time || 'TBA' %></p>
                <p class="mb-3"><i class="bi bi-geo-alt"></i> <%= event.location || 'TBA' %></p>
                <a href="/events/view/<%= event.event_id %>" class="btn btn-sm btn-primary">View Details</a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <%- include('partials/footer') %>

</body>
</html>