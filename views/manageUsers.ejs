<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Users - EventFlow</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
</head>
<body>
    <%- include('partials/header') %>

    <div class="container py-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center bg-light border-bottom">
                <h1 class="h4 mb-0"><i class="bi bi-people"></i> Manage Users</h1>
                <a href="/events" class="btn btn-light btn-sm fw-semibold">
                    <i class="bi bi-arrow-left"></i> Dashboard
                </a>
            </div>
            <div class="card-body">

                <% if (success && success.length > 0) { %>
                  <div class="alert alert-success py-2"><%= success[0] %></div>
                <% } %>

                <% if (error && error.length > 0) { %>
                  <div class="alert alert-danger py-2"><%= error[0] %></div>
                <% } %>

                <% if (users.length === 0) { %>
                    <div class="alert alert-info mb-0">No users found.</div>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% users.forEach(function(u) { %>
                                    <tr>
                                        <td data-label="Name"><%= u.full_name %></td>
                                        <td data-label="Email"><%= u.email %></td>
                                        <td data-label="Role">
                                            <span class="badge <%= u.role === 'admin' ? 'bg-warning text-dark' : 'bg-secondary' %>">
                                                <%= u.role %>
                                            </span>
                                        </td>
                                        <td data-label="Action">
                                            <% if (u.user_id === user.user_id) { %>
                                                <span class="text-muted small">This is you</span>
                                            <% } else { %>
                                                <a href="/admin/users/delete/<%= u.user_id %>" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash"></i> Delete
                                                </a>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>
</body>
</html>