<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - EventFlow</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>

  <%- include('partials/header') %>

  <div class="container py-4">

    <div class="page-hero mb-4 shadow-sm">
      <div class="d-flex flex-column flex-md-row align-items-start justify-content-between gap-3">
        <div>
          <i class="bi bi-calendar-event display-5 text-secondary"></i>
          <h2 class="hero-title mt-3 fw-bold">Welcome, <%= user.full_name %>!</h2>
          <p class="hero-subtitle mb-0">Event Management Dashboard — choose an action to continue.</p>
        </div>
        <div class="text-muted small">
          <p class="mb-1">Admin controls, event browsing, and registration tools in one place.</p>
        </div>
      </div>
    </div>

    <% if (success && success.length > 0) { %>
      <div class="alert alert-success py-2"><%= success[0] %></div>
    <% } %>

    <% if (error && error.length > 0) { %>
      <div class="alert alert-danger py-2"><%= error[0] %></div>
    <% } %>

    <div class="row g-3">
      <% if (user.role === 'admin') { %>
        <div class="col-6 col-md-3">
          <a href="/events/create" class="action-tile">
            <div class="card">
              <i class="bi bi-calendar-plus"></i>
              <span>Create Event</span>
            </div>
          </a>
        </div>
      <% } %>

      <div class="col-6 col-md-3">
        <a href="/events/view" class="action-tile">
          <div class="card">
            <i class="bi bi-list-ul"></i>
            <span>View Events</span>
          </div>
        </a>
      </div>

      <% if (user.role === 'admin') { %>
        <div class="col-6 col-md-3">
          <a href="/events/view" class="action-tile">
            <div class="card">
              <i class="bi bi-pencil-square"></i>
              <span>Edit Event</span>
            </div>
          </a>
        </div>

        <div class="col-6 col-md-3">
          <a href="/events/view" class="action-tile">
            <div class="card">
              <i class="bi bi-trash"></i>
              <span>Delete Event</span>
            </div>
          </a>
        </div>

        <div class="col-6 col-md-3">
          <a href="/admin/users" class="action-tile">
            <div class="card">
              <i class="bi bi-people"></i>
              <span>Manage Users</span>
            </div>
          </a>
        </div>
      <% } %>
    </div>

  </div>

  <%- include('partials/footer') %>

</body>
</html>