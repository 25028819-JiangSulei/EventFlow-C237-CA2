<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Delete Event - EventFlow</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>

  <%- include('partials/header') %>

  <div class="container">
    <div class="row justify-content-center align-items-center py-5">
      <div class="col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm danger-panel">
          <div class="card-header text-center py-4 bg-danger bg-opacity-10 border-bottom border-danger border-opacity-25">
            <i class="bi bi-exclamation-triangle display-6 text-danger"></i>
            <h3 class="mt-2 fw-bold mb-0 text-danger">Delete Event</h3>
          </div>
          <div class="card-body p-4 p-md-5">

            <% if (error && error.length > 0) { %>
              <div class="alert alert-danger py-2"><%= error[0] %></div>
            <% } %>

            <p class="text-center">
              Are you sure you want to delete this event? This action cannot be undone.
            </p>

            <div class="border rounded p-3 mb-4">
              <p class="mb-1"><i class="bi bi-calendar-event"></i> <strong><%= event.event_name %></strong></p>
              <p class="mb-1 text-muted"><i class="bi bi-calendar3"></i> <%= event.event_date %> at <%= event.event_time %></p>
              <p class="mb-0 text-muted"><i class="bi bi-geo-alt"></i> <%= event.location %></p>
            </div>

            <form action="/events/delete/<%= event.event_id %>" method="POST">
              <div class="d-flex gap-2">
                <a href="/events/view/<%= event.event_id %>" class="btn btn-outline-primary w-50 py-2 fw-semibold">
                  <i class="bi bi-arrow-left"></i> Cancel
                </a>
                <button type="submit" class="btn btn-danger w-50 py-2 fw-semibold">
                  <i class="bi bi-trash"></i> Yes, Delete
                </button>
              </div>
            </form>

          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

</body>
</html>